-#undef	YYPURE
-#define	YYPURE	1
-
-#define	YYPARSE_PARAM	arg
-#define	YYLEX_PARAM	arg
-
-#define _mdir_error(foo)	_mdir_mem_forget(arg, 1)
-
-int yylex();
+#define _mdir_error(x, msg)	_mdir_mem_forget(arg, 1)
 
 /*
