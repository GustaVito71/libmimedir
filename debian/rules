#!/usr/bin/make -f

export DH_VERBOSE = 1

%:
	dh $@ --with autoreconf

override_dh_autoreconf:
	libtoolize --force --copy
	ACLOCAL="aclocal -I m4" dh_autoreconf

override_dh_auto_configure:
	dh_auto_configure -- --prefix=/usr

override_dh_auto_build:
	$(MAKE) -j1

override_dh_makeshlibs:
	dh_makeshlibs -V 'libmimedir0 (>= 0.5.1-0~bookworm1)'

override_dh_install:
	dh_install
